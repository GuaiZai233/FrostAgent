{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/web/src",
  "i18n": {
    "sourceLocale": "zh-CN",
    "locales": {
      "en": {
        "translation": "apps/web/src/locale/messages.en.xlf",
        "subPath": "en"
      }
    }
  },
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "dependsOn": ["proto:generate-web"],
      "options": {
        "outputPath": {
          "base": "internal/frontend/dist",
          "browser": ""
        },
        "browser": "apps/web/src/main.ts",
        "polyfills": ["@angular/localize/init"],
        "tsConfig": "apps/web/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/web/public"
          },
          {
            "glob": "**/*",
            "input": "node_modules/monaco-editor/min/vs",
            "output": "assets/monaco-editor/vs"
          }
        ],
        "styles": ["apps/web/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "localize": true,
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "650kb",
              "maximumError": "1.2mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "localize": true,
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "web:build:production"
        },
        "development": {
          "buildTarget": "web:build:development",
          "proxyConfig": "apps/web/proxy.conf.json"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "dependsOn": ["proto:generate-web"],
      "options": {
        "watch": false
      }
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "web:build",
        "format": "xlf",
        "outputPath": "apps/web/src/locale",
        "outFile": "messages.xlf"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "web:build",
        "staticFilePath": "internal/frontend/dist",
        "spa": true
      }
    }
  }
}
